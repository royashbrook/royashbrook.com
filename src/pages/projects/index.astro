---
import Base from '../../layouts/Base.astro';
import { projects } from '../../data/projects.js';
---
<Base title="projects — roy ashbrook">
  <section>
    <p class="marker">&gt; projects</p>
    <p class="note">the things i have worked on and released so that other people can use.</p>
    <div class="cards">
      {projects.map((p) => (
        <div class="card">
          <div class="t">{p.name}</div>
          <div class="d">{p.desc}</div>
          <div class="meta">
            {p.site && <><a href={p.site}>site</a>{' · '}</>}
            <a href={p.repo}>repo</a>
          </div>
        </div>
      ))}
    </div>
  </section>
</Base>
