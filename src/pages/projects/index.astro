---
import Base from '../../layouts/Base.astro';
import { projects, projectLinkOrder } from '../../data/projects.js';
---
<Base title="projects — roy ashbrook">
  <section>
    <p class="marker">&gt; projects</p>
    <p class="note">the things i have worked on and released so that other people can use.</p>
    <div class="cards">
      {projects.map((p) => (
        <div class="card">
          <div class="t">{p.name}</div>
          <div class="d">{p.desc}</div>
          <div class="meta">{projectLinkOrder.filter((k) => p[k]).map((k, i) => (<>{i > 0 ? ' · ' : ''}<a href={p[k]}>{k}</a></>))}</div>
        </div>
      ))}
    </div>
  </section>
</Base>
