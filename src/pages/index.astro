---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
import { projects, projectLinkOrder } from '../data/projects.js';

// real feed off the ported collection — top 3 newest (drafts excluded), plus the live count.
const all = (await getCollection('posts', ({ data }) => !data.draft)).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const fmt = (d) => `${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, '0')}-${String(d.getUTCDate()).padStart(2, '0')}`;
const recent = all.slice(0, 3).map((p) => ({ title: p.data.title, date: fmt(p.data.date), url: `/${p.data.path}/` }));
const count = all.length;
const earliest = all.length ? all[all.length - 1].data.date.getUTCFullYear() : '';
---
<Base>
  <div class="hero">
    <div class="kicker">dad, hub, coder, tech fan</div>
    <p>welcome to my site. i like automation and techy things. sometimes i write something or publish a tool.</p>
  </div>

  <section id="writing">
    <p class="marker">&gt; writing</p>
    <ul class="posts">
      {recent.map((r) => (
        <li><a href={r.url}>{r.title}</a><span class="date">{r.date}</span></li>
      ))}
    </ul>
    <p class="more"><a href="/blog/">{count} posts, back to {earliest} →</a></p>
  </section>

  <section id="projects">
    <p class="marker"><a href="/projects/" style="color:inherit;text-decoration:none;">&gt; projects</a></p>
    <div class="cards">
      {projects.map((p) => (
        <div class="card">
          <div class="t">{p.name}</div>
          <div class="d">{p.desc}</div>
          <div class="meta">{projectLinkOrder.filter((k) => p[k]).map((k, i) => (<>{i > 0 ? ' · ' : ''}<a href={p[k]}>{k}</a></>))}</div>
        </div>
      ))}
    </div>
    <a href="/agents/" style="text-decoration:none;">
      <div class="strip">
        <div class="t">&gt; for ai agents</div>
        <div class="d">sql-spider · blame-mcp · skills + mcps i've made</div>
      </div>
    </a>
  </section>

  <section id="elsewhere">
    <p class="marker">&gt; elsewhere</p>
    <p class="elsewhere"><a href="https://github.com/royashbrook" target="_blank" rel="noopener noreferrer">github</a> · <a href="https://www.linkedin.com/in/royashbrook" target="_blank" rel="noopener noreferrer">linkedin</a></p>
  </section>
</Base>
