---
import Base from '../../layouts/Base.astro';
import { tools } from '../../data/agents.js';
---
<Base title="for ai agents — roy ashbrook">
  <section>
    <p class="marker">&gt; for ai agents</p>
    <p style="font-size:15px;color:var(--muted);line-height:1.8;max-width:56ch;margin:0 0 0.5rem;">small things i've made for ai agents, skills and mcps. clone them, point an agent at them, tell me what breaks.</p>
    <p style="font-size:13px;color:var(--faint);margin:0 0 2rem;">an agent scanning this site can read the machine list at <a href="/llms.txt">/llms.txt</a>.</p>

    {tools.map((t) => (
      <div class="card" style="margin-bottom:0.75rem;">
        <div style="display:flex;align-items:baseline;gap:0.6rem;">
          <span class="t">{t.name}</span>
          <span class="tag">{t.type}</span>
        </div>
        <div class="d">{t.desc}</div>
        <div class="meta">{t.use} · {t.links.map((l, i) => (<>{i > 0 ? ' · ' : ''}<a href={l.url}>{l.label}</a></>))}</div>
      </div>
    ))}
  </section>
</Base>
