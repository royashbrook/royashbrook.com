---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
const fmt = (d) => `${d.getUTCFullYear()}-${String(d.getUTCMonth() + 1).padStart(2, '0')}-${String(d.getUTCDate()).padStart(2, '0')}`;

// group by year for the archive
const byYear = {};
for (const p of posts) {
  const y = p.data.date.getUTCFullYear();
  (byYear[y] ??= []).push(p);
}
const years = Object.keys(byYear).sort((a, b) => b - a);
const earliest = years[years.length - 1];
---
<Base title="writing — roy ashbrook">
  <section style="padding-top:1.5rem;">
    <p class="marker">&gt; writing — {posts.length} posts, back to {earliest}</p>
    <p class="note">things i have written over time. what i was thinking at the time, not always what i think now.</p>
    {years.map((y) => (
      <div style="margin-top:1.75rem;">
        <div style="font-size:13px;color:var(--faint);margin-bottom:0.5rem;">{y}</div>
        <ul class="posts">
          {byYear[y].map((p) => (
            <li><a href={`/${p.data.path}/`}>{p.data.title}</a><span class="date">{fmt(p.data.date)}</span></li>
          ))}
        </ul>
      </div>
    ))}
  </section>
</Base>
