---
import '../styles/global.css';
import Footer from '../components/Footer.astro';
const { title = 'roy ashbrook', description = 'dad, hub, coder, tech fan.' } = Astro.props;
// cloudflare web analytics is injected automatically at the CF edge (zone-level), no snippet needed.
// canonical -> apex, so www (which also serves) doesn't read as duplicate content.
const canonical = new URL(Astro.url.pathname, 'https://royashbrook.com').href;
const nav = [
  { name: 'projects', link: '/projects/' },
  { name: 'agents', link: '/agents/' },
  { name: 'writing', link: '/blog/' },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light dark" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
  </head>
  <body>
    <div class="wrap">
      <header class="site-head">
        <a class="name" href="/">roy ashbrook</a>
        <nav>
          {nav.map((i) => <a href={i.link}>{i.name}</a>)}
        </nav>
      </header>
      <main class="page">
        <slot />
      </main>
      <Footer />
    </div>
  </body>
</html>
