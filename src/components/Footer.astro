---
// roy's maker's mark , the colophon that rides at the bottom of every site he builds, so it reads
// the same everywhere. ported from the lifescored svelte component (src/lib/ui/MakerMark.svelte) to
// astro + this site's css vars. the heart is an inline svg (no icon font / emoji); the red heart and
// gold "sponsor" stay literal so the mark looks identical across sites regardless of each theme.
---
<footer class="colophon">
  <div class="rule"></div>
  <p class="mark">
    made with <svg aria-hidden="true" viewBox="0 0 24 24" class="heart"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg><span class="sr-only">love</span>
    by
    <a href="https://royashbrook.com" target="_blank" rel="noreferrer">roy</a>
    +
    <a href="https://royashbrook.com/agents/" target="_blank" rel="noreferrer">ai</a>
    <span aria-hidden="true" class="dot">·</span>
    <a class="sponsor" href="https://github.com/sponsors/royashbrook" target="_blank" rel="noreferrer">sponsor me</a>
  </p>
</footer>

<style>
  .colophon { margin-top: 3.5rem; padding-bottom: 2rem; }
  .rule { height: 1px; width: 10rem; margin: 0 auto 1.1rem; background: var(--line); }
  .mark { text-align: center; font-family: var(--mono); font-size: 12px; color: var(--muted); margin: 0; line-height: 1.7; }
  .heart { display: inline-block; width: .85em; height: .85em; fill: #e0746a; vertical-align: -.1em; }
  .mark a { color: var(--fg); text-decoration: underline; }
  .mark a:hover { color: var(--accent); }
  .mark a.sponsor { color: #d9a441; }
  .dot { opacity: .45; }
  .sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0; }
</style>
