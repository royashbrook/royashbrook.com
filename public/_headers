# the game must not be edge/browser-cached. it's a self-versioning PWA served on stable URLs, so a
# cached config.js/js/index.html makes a deploy's new version + code lag behind (CF edge-serves stale
# HITs even with must-revalidate). no-store keeps every online load current; offline is unaffected
# because the service worker precaches into the Cache API, which no-store does not govern.
/craftrush/*
  Cache-Control: no-store

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Content-Security-Policy: frame-ancestors 'none'
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  Strict-Transport-Security: max-age=31536000
